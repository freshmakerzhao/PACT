    "version": "0.2.0",
    "configurations": [
        // ================================= excavator_simple =================================
        {
            // 生成轨迹数据
            "name": "[excavator] lifting_cube_scripted record_sim_episodes",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/record_sim_episodes.py",
            "console": "integratedTerminal",
            "args": [
                "--task_name", "sim_lifting_cube_scripted",
                "--dataset_dir", "./data_sim_episodes/excavator_simple/sim_lifting_cube_scripted_260226",
                "--num_episodes", "1",
                "--equipment_model", "excavator_simple",
                "--onscreen_render"
            ],
        },
        {
            // 可视化轨迹数据
            "name": "[excavator] lifting_cube_scripted visualize_episodes",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/visualize_episodes.py",
            "console": "integratedTerminal",
            "args": [
                "--dataset_dir", "./data_sim_episodes/excavator_simple/sim_lifting_cube_scripted_260226",
                "--episode_idx", "0"
            ],
        },
        {
            // 训练模型
            "name": "[excavator] lifting_cube_scripted train",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/imitate_episodes.py",
            "console": "integratedTerminal",
            "args": [
                "--task_name", "sim_lifting_cube_scripted",
                "--ckpt_dir", "./ckpts/sim_lifting_cube_scripted",
                "--policy_class", "ACT",
                "--kl_weight", "10",
                "--chunk_size", "100",
                "--hidden_dim", "512",
                "--batch_size", "8",
                "--dim_feedforward", "3200",
                "--num_epochs", "2000",
                "--lr", "1e-5",
                "--seed", "0",
                "--equipment_model", "excavator_simple",
            ],
        },
        {
            // 验证模型
            "name": "[excavator] lifting_cube_scripted eval",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/imitate_episodes.py",
            "console": "integratedTerminal",
            "args": [
                "--task_name", "sim_lifting_cube_scripted",
                "--ckpt_dir", "./ckpts/sim_lifting_cube_scripted",
                "--policy_class", "ACT",
                "--kl_weight", "10",
                "--chunk_size", "100",
                "--hidden_dim", "512",
                "--batch_size", "8",
                "--dim_feedforward", "3200",
                "--num_epochs", "2000",
                "--lr", "1e-5",
                "--seed", "0",
                "--equipment_model", "excavator_simple",
                "--eval"
            ],
        },
